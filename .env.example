# NovelMotion — copy this file to .env and fill in your values.
# Never commit .env (it is in .gitignore).

# Hugging Face (SD models, gated/private)
# HF_TOKEN=your_token_here

# LLM for AI prompt engine (--prompt-engine ai)
# GOOGLE_API_KEY=...   # for Gemini
# OPENAI_API_KEY=...   # for OpenAI-compatible
# LLM_API_KEY=...      # fallback
